{
  "name": "zenml-tutorial",
  "displayName": "ZenML Tutorial",
  "repository": {
    "type": "git",
    "url": "https://github.com/zenml-io/vscode-tutorial-extension"
  },
  "description": "Interactive ZenML pipeline tutorials with step-by-step guidance and one-click execution",
  "version": "0.1.3",
  "publisher": "zenml-io",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "keywords": [
    "zenml",
    "machine learning",
    "mlops",
    "tutorial",
    "codespace",
    "python"
  ],
  "icon": "assets/zenml-icon.png",
  "license": "Apache-2.0",
  "activationEvents": [
    "onStartupFinished",
    "onView:zenmlTutorialView"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "buildExtension": "vsce package && mkdir -p .devcontainer/extensions && rm -f .devcontainer/extensions/zenml-tutorial* && mv zenml-tutorial* .devcontainer/extensions"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-cli": "^0.1.1",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.6.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.36",
    "marked": "^13.0.1"
  },
  "contributes": {
    "commands": [
      {
        "command": "zenml.startTutorial",
        "title": "Start ZenML Tutorial",
        "category": "ZenML",
        "icon": "$(play)"
      },
      {
        "command": "zenml.openHomepage",
        "title": "Open ZenML Tutorial Homepage",
        "category": "ZenML",
        "icon": "$(home)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "zenml.startTutorial",
          "when": "true"
        },
        {
          "command": "zenml.openHomepage",
          "when": "true"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "zenmlTutorial",
          "title": "ZenML Tutorial",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "zenmlTutorial": [
        {
          "id": "zenmlTutorialView",
          "name": "Tutorial",
          "when": "true"
        }
      ]
    },

    "configuration": {
      "title": "ZenML",
      "properties": {
        "zenml.dashboardUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Base URL for the ZenML dashboard"
        },
        "zenml.autoOpenTutorial": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the ZenML tutorial homepage when starting VS Code"
        }
      }
    },
    "themes": [
      {
        "label": "ZenML Color Theme",
        "uiTheme": "vs",
        "path": "./themes/ZenML-color-theme.json"
      }
    ]
  }
}
