{
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "files.insertFinalNewline": true,
        "workbench.startupEditor": "none"
      },
      "extensions": [
        "ZenML.zenml-codespace-tutorial"
      ]
    }
  },
  "containerEnv": {
    "PYTHONPATH": "/workspaces/vscode-tutorial-extension/tutorials/pipelines"
  }
}
